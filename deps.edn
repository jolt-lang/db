{:paths ["clj"]

 ;; SQLite (libsqlite3) and PostgreSQL (libpq) are bound natively via jolt.ffi
 ;; (db.sqlite / db.pg) — no jpm modules. The system shared libraries must be
 ;; present at runtime (libsqlite3 ships on macOS and most Linux distros; libpq
 ;; only when the postgres backend is used).

 :aliases {:test {:extra-paths ["clj-test"]
                  :main-opts ["-m" "jdbc.core-test"]}}

 :tasks {test "joltc -M:test"}}
